rules_version='2'
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }

    match /products/{productId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.author.uid;
      allow update: if request.auth != null && request.auth.uid == resource.data.author.uid
                    && request.resource.data.author.uid == resource.data.author.uid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.author.uid;
    }

    match /users/{userId}/wishlist/{productId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/cart/{productId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
